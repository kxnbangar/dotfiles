(setf *startup-message* "Welcome to Bangar's System"

      ;;IResize
      *resize-increment* 32

      ;;Message and Input
      *input-window-gravity*   :center
      *message-window-gravity* :center

      ;;Mode line
      *mode-line-timeout* 2
      *screen-mode-line-format* " [%g] | %W |^> %I | Battery: %B | %d "

      ;;Groups
      *group-format* "%t")
